<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Словарь физических терминов</title>
    <style>
        :root {
            --bg: #f5f7fa;
            --card-bg: #ffffff;
            --text: #1a1a2e;
            --text-secondary: #4a4a6a;
            --accent: #2c3e50;
            --accent-light: #e8ecf1;
            --border: #eef0f5;
            --hover: #f0f3f8;
            --shadow: 0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.03);
            --radius: 16px;
            --radius-sm: 10px;
            --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: var(--bg);
            min-height: 100vh;
            padding: 40px 20px;
            color: var(--text);
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            margin-bottom: 36px;
        }

        .header h1 {
            font-size: 2rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: var(--accent);
        }

        .header p {
            color: var(--text-secondary);
            margin-top: 6px;
            font-size: 0.9rem;
            font-weight: 450;
        }

        .dictionary-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
        }

        .accordion-list {
            padding: 0;
        }

        .letter-item {
            border-bottom: 1px solid var(--border);
        }
        .letter-item:last-child {
            border-bottom: none;
        }

        .letter-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 24px;
            cursor: pointer;
            transition: background var(--transition);
            user-select: none;
        }
        .letter-header:hover {
            background: var(--hover);
        }

        .letter-title {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .letter-icon {
            font-size: 22px;
            font-weight: 700;
            color: var(--accent);
            background: var(--accent-light);
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
        }

        .letter-name {
            font-size: 18px;
            font-weight: 600;
            color: var(--text);
        }

        .arrow-icon {
            font-size: 16px;
            color: var(--text-secondary);
            transition: transform var(--transition);
        }
        .arrow-icon.open {
            transform: rotate(90deg);
        }

        .terms-list {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.35s ease;
            background: #fafbfc;
            border-top: 1px solid transparent;
        }
        .terms-list.show {
            max-height: 3000px;
            border-top-color: var(--border);
        }

        .terms-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 8px;
            padding: 16px 24px 24px 24px;
        }

        .term-btn {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 10px 14px;
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text);
            cursor: pointer;
            transition: all var(--transition);
            text-align: left;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .term-btn::before {
            content: "▸";
            font-size: 10px;
            color: var(--text-secondary);
            flex-shrink: 0;
            transition: transform var(--transition);
        }
        .term-btn:hover {
            background: #f6f8fb;
            border-color: #c0c8d4;
            transform: translateX(2px);
        }
        .term-btn:hover::before {
            transform: translateX(2px);
            color: var(--accent);
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 15, 30, 0.4);
            backdrop-filter: blur(2px);
            justify-content: center;
            align-items: center;
            z-index: 1000;
            padding: 20px;
        }

        .modal-content {
            background: var(--card-bg);
            max-width: 680px;
            width: 100%;
            border-radius: var(--radius);
            box-shadow: 0 8px 30px rgba(0,0,0,0.12);
            max-height: 80vh;
            overflow-y: auto;
            border: 1px solid var(--border);
        }

        .modal-header {
            background: var(--card-bg);
            padding: 16px 22px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .modal-header h2 {
            font-size: 1.15rem;
            font-weight: 650;
            color: var(--accent);
            margin: 0;
        }

        .modal-close {
            font-size: 22px;
            cursor: pointer;
            color: var(--text-secondary);
            line-height: 1;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all var(--transition);
        }
        .modal-close:hover {
            background: var(--hover);
            color: var(--text);
        }

        .modal-body {
            padding: 22px;
        }

        .definition-text {
            background: #fafbfc;
            padding: 18px;
            border-radius: 12px;
            line-height: 1.65;
            color: var(--text);
            font-size: 0.92rem;
            border: 1px solid var(--border);
        }

        @media (max-width: 600px) {
            body {
                padding: 20px 12px;
            }
            .header h1 {
                font-size: 1.6rem;
            }
            .terms-grid {
                grid-template-columns: 1fr;
                padding: 12px 16px 20px 16px;
            }
            .letter-header {
                padding: 12px 16px;
            }
            .modal-body {
                padding: 16px;
            }
            .definition-text {
                padding: 14px;
                font-size: 0.85rem;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>Словарь физических терминов</h1>
        <p>В том числе дополнительные вопросы к билетам экзамена</p>
        <p style="font-size: 0.8rem; color: #888; margin-top: 2px;">Может помочь перед экзаменом (но я за это не ручаюсь)</p>
    </div>

    <div class="dictionary-card">
        <div id="accordionContainer" class="accordion-list"></div>
    </div>
</div>

<div id="termModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTermName"></h2>
            <span class="modal-close">&times;</span>
        </div>
        <div class="modal-body">
            <div class="definition-text" id="modalDefinition"></div>
        </div>
    </div>
</div>

<script>
    const dictionary = {
        "А": [
            { term: "Абсолютная влажность", definition: "Масса водяного пара в единице объёма воздуха. Измеряется в г/м³ или кг/м³ (СИ). (Билет №13)" },
            { term: "Аккомодация", definition: "Способность глаза изменять кривизну хрусталика для получения чёткого изображения предметов, находящихся на различных расстояниях. При аккомодации меняется фокусное расстояние оптической системы глаза. (Билет №14)" },
            { term: "Ампер (А)", definition: "Единица силы тока в СИ. 1 А равен силе неизменяющегося тока, который при прохождении по двум параллельным бесконечно длинным проводникам ничтожно малого сечения, расположенным в вакууме на расстоянии 1 м друг от друга, вызывает на каждом метре длины силу взаимодействия 2·10⁻⁷ Н. (Билеты №1, №5, №10, №11, №12, №15)" },
            { term: "Амперметр", definition: "Электроизмерительный прибор для измерения силы тока. Включается в цепь последовательно. Обладает малым внутренним сопротивлением (в идеале — нулевым), чтобы не вносить искажений в режим цепи. Шкала градуируется в амперах или долях ампера. В основе лежит гальванометр с шунтом. (Билеты №1, №5, №10, №15)" }
        ],
        "Б": [
            { term: "Близорукость (миопия)", definition: "Дефект зрения, при котором изображение удалённого предмета фокусируется перед сетчаткой. Возникает либо из-за увеличенной длины глаза, либо из-за избыточной оптической силы хрусталика. Корректируется рассеивающими (отрицательными) линзами. (Билет №14)" }
        ],
        "В": [
            { term: "Ватт (Вт)", definition: "Единица мощности в СИ. 1 Вт = 1 Дж/с. Для электрической цепи: мощность, при которой за 1 с совершается работа 1 Дж; P = U·I. (Билет №11)" },
            { term: "Вектор магнитной индукции (B)", definition: "Силовая характеристика магнитного поля. Направление вектора B в данной точке совпадает с направлением северного полюса магнитной стрелки, помещённой в эту точку. Модуль B определяется через силу Ампера: B = F_A / (I·L·sinα). Единица измерения: Тесла (Тл) = Н/(А·м). (Билеты №1, №12)" },
            { term: "Внутренняя энергия (U)", definition: "Сумма кинетической энергии теплового движения частиц и потенциальной энергии их взаимодействия. Не включает кинетическую энергию движения тела как целого и потенциальную энергию во внешних полях. Изменяется путём совершения работы и теплопередачи. (Билеты №4, №6, №7, №8)" },
            { term: "Вольт (В)", definition: "Единица напряжения и разности потенциалов в СИ. Напряжение 1 В между двумя точками цепи, если при перемещении заряда 1 Кл совершается работа 1 Дж: 1 В = 1 Дж/Кл. (Билеты №5, №10, №11, №15)" },
            { term: "Вольтметр", definition: "Электроизмерительный прибор для измерения напряжения. Включается параллельно участку цепи. Обладает большим внутренним сопротивлением (в идеале — бесконечным), чтобы не шунтировать исследуемый участок. В основе — гальванометр с добавочным сопротивлением. (Билеты №1, №5, №10, №15)" }
        ],
        "Г": [
            { term: "Гальванометр", definition: "Высокочувствительный электроизмерительный прибор магнитоэлектрической системы. Состоит из постоянного магнита, подвижной катушки с током и стрелки. Принцип действия основан на вращающем моменте сил Ампера, действующих на рамку с током в магнитном поле. Используется как основа для амперметров (с шунтом) и вольтметров (с добавочным сопротивлением). (Билеты №1, №5, №10, №15)" },
            { term: "Геометрическая оптика", definition: "Раздел оптики, изучающий законы распространения света в прозрачных средах на основе представления о световых лучах. Справедлива в приближении малой длины волны (λ → 0), когда дифракционными эффектами можно пренебречь. Основные законы: прямолинейного распространения, отражения, преломления. (Билеты №2, №3, №14)" },
            { term: "Главная оптическая ось", definition: "Прямая, проходящая через центры кривизны обеих сферических поверхностей линзы (через оптический центр). Для тонкой линзы — ось симметрии. (Билеты №2, №3, №14)" },
            { term: "Главный фокус линзы", definition: "Точка на главной оптической оси, в которой после преломления в линзе пересекаются лучи, падавшие на линзу параллельно главной оптической оси. Для собирающей линзы — действительный фокус, для рассеивающей — мнимый (пересекаются продолжения лучей). (Билеты №2, №3, №14)" }
        ],
        "Д": [
            { term: "Дальнозоркость (гиперметропия)", definition: "Дефект зрения, при котором изображение удалённого предмета фокусируется за сетчаткой. Возникает из-за укороченной длины глаза или недостаточной оптической силы хрусталика. Корректируется собирающими (положительными) линзами. (Билет №14)" },
            { term: "Двигатель внутреннего сгорания (ДВС)", definition: "Тепловая машина, в которой химическая энергия топлива, сгорающего непосредственно в рабочей полости (цилиндре), преобразуется в механическую работу. Рабочий цикл четырёхтактного ДВС: впуск горючей смеси, сжатие, рабочий ход (сгорание и расширение), выпуск отработанных газов. (Билет №7)" },
            { term: "Действительное изображение", definition: "Изображение, образованное пересечением самих лучей, прошедших через оптическую систему (а не их продолжений). Может быть получено на экране или фотопластинке. (Билеты №2, №3, №14)" },
            { term: "Диамагнетики", definition: "Вещества, намагничивающиеся во внешнем магнитном поле против направления поля. Магнитная проницаемость μ < 1 (чуть меньше единицы). Примеры: медь, серебро, вода, инертные газы. Эффект диамагнетизма универсален, но слаб и маскируется парамагнетизмом, если последний присутствует. (Билет №12)" },
            { term: "Динамическое равновесие", definition: "Состояние системы, при котором скорость прямого процесса (испарения) равна скорости обратного (конденсации). При этом макроскопические параметры системы (масса жидкости, плотность пара) остаются постоянными. (Билет №13)" },
            { term: "Диэлектрики", definition: "Вещества, в которых практически отсутствуют свободные носители заряда. Все электроны прочно связаны с атомами или молекулами. В электрическом поле происходит поляризация диэлектрика — смещение связанных зарядов. Не проводят постоянный ток. Примеры: стекло, резина, дистиллированная вода. (Билет №9)" }
        ],
        "З": [
            { term: "Закон Джоуля — Ленца", definition: "Количество теплоты Q, выделяющееся в неподвижном проводнике с током, прямо пропорционально квадрату силы тока I, сопротивлению проводника R и времени протекания t: Q = I²Rt. Мощность тепловыделения P = I²R. (Билет №11)" },
            { term: "Закон Кулона", definition: "Сила взаимодействия F двух неподвижных точечных зарядов q₁ и q₂ в вакууме прямо пропорциональна произведению модулей зарядов и обратно пропорциональна квадрату расстояния r между ними: F = k|q₁q₂|/r², где k = 1/(4πε₀). Силы направлены вдоль прямой, соединяющей заряды; одноимённые отталкиваются, разноимённые притягиваются. (Билет №9)" },
            { term: "Закон Ома для однородного участка цепи", definition: "Сила тока I на участке цепи, не содержащем ЭДС, прямо пропорциональна напряжению U на этом участке и обратно пропорциональна его сопротивлению R: I = U/R. Физический смысл углового коэффициента прямой I(U) — проводимость 1/R. (Билеты №10, №15)" },
            { term: "Закон Ома для полной цепи", definition: "I = E / (R + r), где E — ЭДС источника, R — сопротивление внешней цепи, r — внутреннее сопротивление источника. (Билет №15)" },
            { term: "Закон преломления света (Снеллиуса)", definition: "Луч падающий, луч преломлённый и нормаль к границе раздела сред, проведённая в точке падения, лежат в одной плоскости. Отношение синуса угла падения α к синусу угла преломления β есть величина постоянная для двух данных сред и равна обратному отношению показателей преломления: sinα/sinβ = n₂/n₁. (Билеты №2, №3, №14)" },
            { term: "Закон прямолинейного распространения света", definition: "В однородной прозрачной среде свет распространяется прямолинейно. Является следствием принципа Ферма: свет выбирает путь, требующий минимального времени. (Билеты №2, №3, №14)" },
            { term: "Закон отражения света", definition: "Луч падающий, луч отражённый и нормаль к отражающей поверхности, проведённая в точке падения, лежат в одной плоскости. Угол отражения равен углу падения: α = α'. Также выводится из принципа Ферма. (Билет №14)" },
            { term: "Закон сохранения электрического заряда", definition: "В электрически изолированной системе алгебраическая сумма зарядов всех тел остаётся постоянной при любых взаимодействиях. Заряд не создаётся и не уничтожается, а лишь перераспределяется между телами. (Билет №9)" },
            { term: "Законы параллельного соединения", definition: "1) Напряжения на всех ветвях одинаковы: U = U₁ = U₂ = ... 2) Сила тока в неразветвлённой части равна сумме токов в ветвях: I = I₁ + I₂ + ... 3) Эквивалентное сопротивление: 1/R_экв = 1/R₁ + 1/R₂ + ... (Билеты №5, №10, №15)" },
            { term: "Законы последовательного соединения", definition: "1) Сила тока во всех элементах одинакова: I = I₁ = I₂ = ... 2) Полное напряжение равно сумме напряжений на элементах: U = U₁ + U₂ + ... 3) Эквивалентное сопротивление: R_экв = R₁ + R₂ + ... (Билеты №5, №10, №15)" },
            { term: "Зеркальное отражение", definition: "Отражение от гладкой поверхности, при котором падающий параллельный пучок света остаётся параллельным после отражения. Выполняется закон отражения для каждой точки. Примеры: плоское зеркало, гладкая поверхность воды. (Билет №14)" },
            { term: "Зоны видности плоского зеркала", definition: "Область пространства, из которой можно видеть изображение источника в зеркале. Строится путём проведения лучей от изображения к краям зеркала; зона видности — между этими лучами и поверхностью зеркала. (Билет №14)" }
        ],
        "И": [
            { term: "Излучение", definition: "Вид теплопередачи, осуществляемый посредством электромагнитных волн (преимущественно ИК-диапазона). Не требует наличия среды между телами. (Билет №6)" },
            { term: "Испарение", definition: "Парообразование, происходящее со свободной поверхности жидкости при любой температуре. Скорость испарения растёт с температурой, площадью поверхности и скоростью удаления пара. Молекулярный механизм: наиболее быстрые молекулы преодолевают силы притяжения и покидают жидкость, средняя кинетическая энергия оставшихся падает — жидкость охлаждается. (Билет №13)" },
            { term: "Источник тока", definition: "Устройство, в котором сторонние силы (не электростатические) совершают работу по разделению электрических зарядов, создавая и поддерживая ЭДС. Примеры: гальванический элемент (химические силы), аккумулятор, генератор (силы Лоренца). (Билеты №5, №10, №15)" }
        ],
        "К": [
            { term: "Калориметр", definition: "Прибор для измерения количества теплоты. Состоит из двух сосудов, разделённых теплоизолирующей прослойкой для минимизации теплообмена с окружающей средой. Внутренний сосуд сделан из материала с хорошей теплопроводностью. (Билеты №4, №8)" },
            { term: "Кипение", definition: "Интенсивное парообразование, происходящее не только с поверхности, но и по всему объёму жидкости (в пузырьках пара). (Билет №13)" },
            { term: "Количество теплоты (Q)", definition: "Энергия, переданная телу путём теплопередачи (без совершения работы). Единица измерения: Джоуль (Дж). При нагревании/охлаждении: Q = cmΔT. (Билеты №4, №8)" },
            { term: "Конвекция", definition: "Вид теплопередачи, осуществляемый путём переноса вещества (потоками жидкости или газа). Естественная конвекция возникает из-за разности плотностей нагретых и холодных слоёв. Вынужденная — под действием внешних устройств (насос, вентилятор). (Билет №6)" },
            { term: "Конденсация", definition: "Процесс перехода вещества из газообразного состояния в жидкое. Происходит при отводе энергии. Скорость конденсации зависит от концентрации пара и его температуры. (Билет №13)" },
            { term: "КПД теплового двигателя (η)", definition: "Отношение полезной механической работы A, совершённой двигателем, к количеству теплоты Q_н, полученному от нагревателя: η = A / Q_н = (Q_н - Q_х) / Q_н, где Q_х — тепло, отданное холодильнику. (Билет №7)" }
        ],
        "Л": [
            { term: "Лампа накаливания", definition: "Источник света, в котором излучение испускает вольфрамовая нить, нагреваемая электрическим током до высокой температуры (~2500–3000°C). Нить тонкая и свёрнута в спираль для увеличения сопротивления и уменьшения теплопотерь. Колба заполнена инертным газом (аргон, криптон) при пониженном давлении для замедления испарения вольфрама. (Билет №11)" },
            { term: "Линза", definition: "Прозрачное тело, ограниченное двумя сферическими (или сферической и плоской) поверхностями. По оптическим свойствам делятся на собирающие и рассеивающие. (Билеты №2, №3, №14)" },
            { term: "Линейное увеличение (Γ)", definition: "Отношение линейного размера изображения H к линейному размеру предмета h: Γ = H/h. Для тонкой линзы Γ = |b|/a, где a — расстояние от предмета до линзы, b — от линзы до изображения. (Билеты №2, №3, №14)" },
            { term: "Линии магнитной индукции (магнитные линии)", definition: "Непрерывные линии, касательные к которым в каждой точке совпадают с направлением вектора магнитной индукции B. Также определяются как линии, по которым ориентируются оси магнитных стрелок, помещённых в поле. Свойства: всегда замкнуты (поле вихревое), не пересекаются, густота характеризует модуль B. (Билеты №1, №12)" },
            { term: "Лупа", definition: "Короткофокусная собирающая линза. Предмет располагается между лупой и её фокусом, создавая мнимое, прямое, увеличенное изображение. Угловое увеличение лупы Γ = d₀/f, где d₀ = 25 см — расстояние наилучшего зрения, f — фокусное расстояние. (Билет №14)" }
        ],
        "М": [
            { term: "Магнитная проницаемость (μ)", definition: "Безразмерная величина, показывающая, во сколько раз индукция магнитного поля B в веществе больше индукции B₀ в вакууме при одинаковых внешних условиях: μ = B/B₀. (Билет №12)" },
            { term: "Магнитное поле", definition: "Особая форма материи, посредством которой осуществляется силовое взаимодействие движущихся электрических зарядов. Свойства: порождается токами и переменным электрическим полем; обнаруживается по действию на токи и движущиеся заряды; является вихревым (линии замкнуты). (Билеты №1, №12)" },
            { term: "Мнимое изображение", definition: "Изображение, образованное пересечением не самих лучей, а их геометрических продолжений. Не может быть получено на экране. (Билеты №2, №3, №14)" },
            { term: "Мнимый источник", definition: "Точка, в которой пересекаются продолжения лучей, падающих на оптическую систему. Используется при расчёте сложных систем, где промежуточное изображение играет роль источника для последующих элементов. (Билеты №2, №3, №14)" },
            { term: "Мощность тока (P)", definition: "Работа электрического тока в единицу времени. P = A/t = U·I. Для резистора: P = I²R = U²/R. Единица: Ватт (Вт). (Билет №11)" }
        ],
        "Н": [
            { term: "Насыщенный пар", definition: "Пар, находящийся в состоянии динамического равновесия со своей жидкостью. Давление и плотность насыщенного пара зависят только от температуры и рода вещества, но не от объёма. Зависимость плотности от температуры — возрастающая нелинейная. (Билет №13)" },
            { term: "Напряжение (U)", definition: "Скалярная физическая величина, равная суммарной работе кулоновских и сторонних сил по перемещению единичного положительного заряда между двумя точками цепи: U₁₂ = (A_кул + A_стор)/q = φ₁ - φ₂ + E₁₂. Единица: Вольт (В). (Билеты №5, №10, №11, №15)" },
            { term: "Напряжённость электрического поля (E)", definition: "Векторная силовая характеристика электрического поля. Определяется как отношение силы, действующей на неподвижный пробный заряд q, к величине этого заряда: E = F/q. Единица: Н/Кл = В/м. (Билет №9)" }
        ],
        "О": [
            { term: "Оптическая сила линзы (D)", definition: "Величина, обратная фокусному расстоянию линзы: D = 1/f. Единица: диоптрия (дптр). 1 дптр — оптическая сила линзы с фокусным расстоянием 1 м. Для собирающих линз D > 0, для рассеивающих D < 0. (Билеты №2, №3, №14)" },
            { term: "Оптический центр линзы", definition: "Точка тонкой линзы, проходя через которую луч не изменяет своего направления (не преломляется). Лежит на пересечении главной оптической оси с линзой. (Билеты №2, №3, №14)" },
            { term: "Относительная влажность (φ)", definition: "Отношение абсолютной влажности ρ к плотности насыщенного пара ρ_н при данной температуре, выраженное в процентах: φ = (ρ/ρ_н) × 100%. Также может определяться через парциальное давление: φ = (p/p_н) × 100%. (Билет №13)" }
        ],
        "П": [
            { term: "Параксиальное приближение", definition: "Приближение, в котором рассматриваются только лучи, идущие под малыми углами к главной оптической оси и на малых расстояниях от неё (приосевые, параксиальные лучи). В этом приближении сферическая аберрация отсутствует, и все лучи от точки собираются в точку. (Билеты №2, №3, №14)" },
            { term: "Парамагнетики", definition: "Вещества, намагничивающиеся во внешнем магнитном поле по направлению поля. Магнитная проницаемость μ > 1 (немного больше единицы). Примеры: алюминий, платина, кислород, хлористое железо. (Билет №12)" },
            { term: "Паровая турбина", definition: "Тепловая машина роторного типа, в которой потенциальная энергия сжатого и нагретого пара преобразуется в кинетическую энергию струи, а затем — в механическую энергию вращения ротора с лопатками. Рабочее тело — водяной пар. (Билет №7)" },
            { term: "Первое начало термодинамики", definition: "Изменение внутренней энергии ΔU термодинамической системы равно сумме количества теплоты Q, переданного системе, и работы A_внеш, совершённой внешними силами над системой: ΔU = Q + A_внеш. Эквивалентная форма: Q = ΔU + A_газа, где A_газа — работа, совершённая системой против внешних сил. (Билеты №4, №6, №8)" },
            { term: "Перископ", definition: "Оптический прибор для наблюдения из укрытия. Состоит из двух параллельных плоских зеркал (или призм), установленных под углом 45° к оси трубы. Изображение мнимое, прямое, равное. (Билет №14)" },
            { term: "Плавкий предохранитель", definition: "Устройство для защиты электрической цепи от токовых перегрузок и короткого замыкания. Представляет собой легкоплавкую проволочку, включённую последовательно в цепь. При превышении допустимого тока проволочка расплавляется (перегорает), размыкая цепь. (Билет №11)" },
            { term: "Плоское зеркало", definition: "Плоская поверхность, зеркально отражающая свет. Изображение предмета: мнимое, прямое, равное по размеру, симметричное относительно плоскости зеркала. (Билет №14)" },
            { term: "Побочная оптическая ось", definition: "Любая прямая, проходящая через оптический центр линзы и отличная от главной оптической оси. (Билеты №2, №3, №14)" },
            { term: "Побочный фокус", definition: "Точка пересечения пучка лучей, падающих на линзу параллельно побочной оптической оси, с фокальной плоскостью. (Билеты №2, №3, №14)" },
            { term: "Постоянный магнит", definition: "Тело, способное длительное время сохранять намагниченность. Имеет два полюса — северный (N) и южный (S). Разноимённые полюсы притягиваются, одноимённые — отталкиваются. Согласно гипотезе Ампера, магнетизм постоянных магнитов обусловлен микротоками (круговыми токами в атомах). При нагреве до точки Кюри доменная структура разрушается, и магнит размагничивается. (Билет №12)" },
            { term: "Потенциометр", definition: "Переменный резистор, включённый по схеме делителя напряжения. Используется для плавного регулирования напряжения, подаваемого на нагрузку. (Билеты №5, №10, №15)" },
            { term: "Правило левой руки (для силы Ампера)", definition: "Если левую руку расположить так, чтобы перпендикулярная проводнику составляющая вектора магнитной индукции B входила в ладонь, а четыре вытянутых пальца указывали направление тока, то отогнутый на 90° большой палец укажет направление силы Ампера. (Билет №1)" },
            { term: "Правило левой руки (для силы Лоренца)", definition: "Если левую руку расположить так, чтобы перпендикулярная скорости частицы составляющая вектора B входила в ладонь, а четыре пальца указывали направление скорости положительного заряда, то отогнутый большой палец укажет направление силы Лоренца. Для отрицательного заряда — направление противоположно. (Билет №1)" },
            { term: "Правило правой руки (для прямого тока)", definition: "Если обхватить проводник правой рукой так, чтобы отогнутый большой палец указывал направление тока, то четыре согнутых пальца укажут направление линий магнитной индукции. (Билет №1)" },
            { term: "Правило правой руки (для соленоида)", definition: "Если обхватить соленоид правой рукой так, чтобы четыре пальца указывали направление тока в витках, то отогнутый большой палец укажет направление вектора магнитной индукции внутри соленоида. (Билет №1)" },
            { term: "Правила знаков в формуле тонкой линзы", definition: "1) a > 0 всегда (предмет действительный). 2) b > 0 — изображение действительное, b < 0 — мнимое. 3) f > 0 — линза собирающая, f < 0 — рассеивающая. (Билеты №2, №3, №14)" },
            { term: "Правила построения изображения в тонкой линзе", definition: "1) Луч, проходящий через оптический центр, не преломляется. 2) Луч, параллельный главной оптической оси, после преломления проходит через главный фокус (для собирающей) или его продолжение (для рассеивающей). 3) Луч, идущий через главный фокус (или к нему), выходит параллельно главной оптической оси. (Билеты №2, №3, №14)" },
            { term: "Проводник", definition: "Вещество, в котором имеются свободные носители заряда, способные перемещаться по всему объёму под действием сколь угодно малого электрического поля. Примеры: металлы (свободные электроны), электролиты (ионы). (Билет №9)" },
            { term: "Психрометр", definition: "Прибор для измерения влажности воздуха. Состоит из двух термометров: сухого (измеряет температуру воздуха) и влажного (резервуар обёрнут влажной тканью). За счёт испарения влажный термометр показывает более низкую температуру. По разности показаний с помощью психрометрической таблицы определяют относительную влажность. (Билет №13)" }
        ],
        "Р": [
            { term: "Работа электрического тока", definition: "A = U·I·t. Выводится из определений напряжения (U = A/q) и силы тока (I = q/t). Для пассивного участка цепи без ЭДС: A = U·I·t = I²Rt = U²t/R. (Билет №11)" },
            { term: "Рассеивающая линза", definition: "Линза, которая преобразует параллельный пучок лучей в расходящийся. В середине тоньше, чем у краёв. Имеет отрицательное фокусное расстояние. Изображение предмета всегда мнимое, прямое, уменьшенное. (Билеты №2, №3, №14)" },
            { term: "Рассеянное (диффузное) отражение", definition: "Отражение света от шероховатой поверхности. Параллельный падающий пучок после отражения рассеивается во все стороны, так как микроучастки поверхности ориентированы хаотично. Благодаря диффузному отражению мы видим предметы, не излучающие собственный свет. (Билет №14)" },
            { term: "Расстояние наилучшего зрения", definition: "Расстояние от глаза до предмета, при котором глаз может длительное время рассматривать его без утомления. Для нормального глаза d₀ ≈ 25 см. (Билет №14)" },
            { term: "Резистор", definition: "Пассивный элемент электрической цепи, обладающий заданным электрическим сопротивлением R. Сопротивление металлического проводника связано с его геометрией: R = ρ·l/S. (Билеты №5, №10, №15)" },
            { term: "Реостат", definition: "Резистор с переменным сопротивлением. Состоит из проволоки с высоким удельным сопротивлением, намотанной на изолятор, и подвижного контакта. Включается в цепь последовательно для регулирования силы тока. (Билеты №5, №10, №15)" }
        ],
        "С": [
            { term: "Световой луч", definition: "Линия, касательная к которой в каждой точке совпадает с направлением распространения световой энергии (нормаль к волновому фронту). В геометрической оптике — основное понятие, с помощью которого описывается распространение света. (Билеты №2, №3, №14)" },
            { term: "Световой пучок", definition: "Совокупность световых лучей. По геометрии: параллельный, сходящийся, расходящийся. (Билеты №2, №3, №14)" },
            { term: "Сетчатка", definition: "Внутренняя оболочка глаза, содержащая светочувствительные рецепторы: палочки (чёрно-белое зрение, сумеречное) и колбочки (цветовое зрение, дневное). На сетчатке формируется действительное, перевёрнутое, уменьшенное изображение предметов. (Билет №14)" },
            { term: "Сила Ампера (F_A)", definition: "Сила, с которой магнитное поле действует на проводник с током, помещённый в это поле. Модуль: F_A = B·I·L·sinα, где α — угол между направлением тока и вектором B. Направление — по правилу левой руки. Сонаправленные токи притягиваются, противонаправленные — отталкиваются (следует из анализа взаимодействия их магнитных полей). (Билет №1)" },
            { term: "Сила Лоренца (F_Л)", definition: "Сила, действующая на движущуюся заряженную частицу со стороны электромагнитного поля. Магнитная составляющая: F_Л = q·v·B·sinα. Направление — по правилу левой руки. Сила Ампера есть суммарная сила Лоренца, действующая на все носители заряда в проводнике. Траектория частицы в однородном магнитном поле: прямая (v ∥ B), окружность (v ⊥ B), винтовая линия (v под углом к B). (Билет №1)" },
            { term: "Сила тока (I)", definition: "Скалярная физическая величина, равная пределу отношения заряда Δq, проходящего через поперечное сечение проводника за интервал времени Δt, к этому интервалу при Δt → 0: I = dq/dt. Для постоянного тока: I = q/t. Единица: Ампер (А). (Билеты №1, №5, №10, №11, №12, №15)" },
            { term: "Силовые линии электрического поля", definition: "Непрерывные линии, касательные к которым в каждой точке совпадают с направлением вектора напряжённости E. Свойства: начинаются на положительных зарядах, заканчиваются на отрицательных; не пересекаются; густота пропорциональна модулю E. (Билет №9)" },
            { term: "Собирающая линза", definition: "Линза, преобразующая параллельный пучок лучей в сходящийся. В середине толще, чем у краёв. Имеет положительное фокусное расстояние. Может давать действительные и мнимые изображения. (Билеты №2, №3, №14)" },
            { term: "Сопротивление (R)", definition: "Физическая величина, характеризующая противодействие проводника направленному движению зарядов: R = U/I. Единица: Ом (Ом). Механизм в металлах: рассеяние электронов на тепловых колебаниях и дефектах кристаллической решётки. (Билеты №5, №10, №11, №15)" }
        ],
        "Т": [
            { term: "Температура", definition: "С точки зрения МКТ — мера средней кинетической энергии хаотического теплового движения молекул: <E_к> = (3/2)kT. С точки зрения термодинамики — параметр, определяющий направление теплопередачи: тепло самопроизвольно передаётся от тел с большей температурой к телам с меньшей. В состоянии теплового равновесия температуры тел равны. (Билеты №4, №6, №8, №13)" },
            { term: "Тепловое движение", definition: "Непрерывное хаотическое движение микрочастиц (молекул, атомов, ионов), из которых состоит вещество. Интенсивность зависит от температуры. (Билет №6)" },
            { term: "Тепловое равновесие", definition: "Состояние системы тел, при котором прекращается макроскопический теплообмен и температуры всех тел выравниваются. Характеризуется постоянством температуры во времени. (Билеты №4, №6, №8)" },
            { term: "Теплоёмкость тела (C)", definition: "Количество теплоты, необходимое для нагревания данного тела на 1 °C (или 1 К): C = Q/ΔT. Единица: Дж/°C. Зависит от массы и вещества тела. (Билеты №4, №8)" },
            { term: "Теплопередача", definition: "Процесс передачи внутренней энергии от более нагретых тел к менее нагретым без совершения макроскопической работы. Виды: теплопроводность, конвекция, излучение. (Билеты №4, №6, №8)" },
            { term: "Теплопроводность", definition: "Вид теплопередачи, при котором энергия передаётся от более нагретых частиц к менее нагретым за счёт их взаимодействия, без макроскопического переноса вещества. Механизм в металлах: передача энергии электронным газом. Вещества с низкой теплопроводностью (изоляторы): дерево, пенопласт, воздух. С высокой: металлы (серебро, медь). Мощность теплопередачи зависит от рода вещества, площади сечения, разности температур и обратно пропорциональна толщине. (Билет №6)" },
            { term: "Тепловая машина", definition: "Устройство, многократно преобразующее внутреннюю энергию топлива в механическую работу. Обязательные элементы: нагреватель (источник энергии), рабочее тело (газ, пар), холодильник (окружающая среда). (Билет №7)" },
            { term: "Тонкая линза", definition: "Линза, толщина которой пренебрежимо мала по сравнению с радиусами кривизны её поверхностей и расстояниями от линзы до предмета и изображения. Позволяет использовать упрощённые правила построения и формулу тонкой линзы. (Билеты №2, №3, №14)" },
            { term: "Точка росы", definition: "Температура, до которой нужно охладить воздух при постоянном давлении, чтобы содержащийся в нём водяной пар достиг состояния насыщения. При понижении температуры ниже точки росы начинается конденсация (образование росы, тумана). (Билет №13)" }
        ],
        "У": [
            { term: "Угол зрения", definition: "Угол между лучами, идущими от крайних точек предмета в оптический центр глаза. От величины угла зависит размер изображения на сетчатке: чем больше угол, тем крупнее изображение. (Билет №14)" },
            { term: "Удельная теплоёмкость (c)", definition: "Количество теплоты, необходимое для нагревания 1 кг вещества на 1 °C (или 1 К): c = Q/(m·ΔT). Единица: Дж/(кг·°C). Характеризует способность вещества накапливать тепловую энергию. (Билеты №4, №8)" },
            { term: "Удельная теплота парообразования (L)", definition: "Количество теплоты, необходимое для превращения 1 кг жидкости в пар при постоянной температуре (для кипения — при температуре кипения). Зависит от рода жидкости и температуры. Единица: Дж/кг. (Билет №13)" },
            { term: "Удельная теплота сгорания (q)", definition: "Количество теплоты, выделяющееся при полном сгорании 1 кг топлива. Высокая: водород (~120 МДж/кг), бензин; низкая: древесина, торф. Единица: Дж/кг. (Билет №7)" },
            { term: "Удельное сопротивление (ρ)", definition: "Физическая величина, характеризующая способность материала препятствовать прохождению тока. Численно равно сопротивлению проводника длиной 1 м и площадью сечения 1 м²: ρ = R·S/l. Единицы: Ом·м (СИ) и Ом·мм²/м (внесистемная); 1 Ом·мм²/м = 10⁻⁶ Ом·м. (Билеты №5, №10, №11, №15)" },
            { term: "Уравнение теплового баланса (УТБ)", definition: "Сумма количеств теплоты, отданных нагретыми телами, равна сумме количеств теплоты, полученных холодными телами в замкнутой теплоизолированной системе: ΣQ_отд = ΣQ_пол. Условия выполнения: система замкнута, нет теплообмена с окружающей средой, не совершается механическая работа. (Билеты №4, №8)" }
        ],
        "Ф": [
            { term: "Ферриты", definition: "Магнитные материалы, представляющие собой оксидные соединения железа с другими металлами. Сочетают свойства ферромагнетиков (μ >> 1) и диэлектриков (или полупроводников). Благодаря высокому удельному сопротивлению в ферритах практически не возникают вихревые токи. Используются в высокочастотной технике. (Билет №12)" },
            { term: "Ферромагнетики", definition: "Вещества, обладающие самопроизвольной (спонтанной) намагниченностью в отсутствие внешнего поля (в доменах). μ >> 1 (до 10⁵). Свойства: гистерезис, наличие точки Кюри T_к, выше которой ферромагнитные свойства исчезают и вещество становится парамагнетиком. Примеры: железо, никель, кобальт и их сплавы. (Билет №12)" },
            { term: "Фокальная плоскость", definition: "Плоскость, проходящая через главный фокус линзы перпендикулярно главной оптической оси. Параллельный пучок лучей собирается в точку на фокальной плоскости. (Билеты №2, №3, №14)" },
            { term: "Фокусное расстояние линзы (f)", definition: "Расстояние от оптического центра линзы до её главного фокуса. Для собирающей линзы f > 0, для рассеивающей f < 0. (Билеты №2, №3, №14)" },
            { term: "Формула тонкой линзы", definition: "1/a + 1/b = 1/f, где a — расстояние от предмета до линзы, b — от линзы до изображения, f — фокусное расстояние. Выводится из подобия треугольников при построении изображений. (Билеты №2, №3, №14)" }
        ],
        "Х": [
            { term: "Химический элемент Даниэля", definition: "Гальванический элемент: цинковый электрод в растворе ZnSO₄, медный — в CuSO₄; растворы разделены пористой перегородкой. Zn окисляется (анод): Zn → Zn²⁺ + 2e⁻; Cu восстанавливается (катод): Cu²⁺ + 2e⁻ → Cu. ЭДС ≈ 1,1 В. (Билеты №5, №10, №15)" },
            { term: "Холодильник (в тепловом двигателе)", definition: "Устройство или окружающая среда, которым рабочее тело тепловой машины отдаёт часть полученной от нагревателя энергии. Без холодильника работа тепловой машины невозможна. (Билет №7)" },
            { term: "Хрусталик", definition: "Прозрачная двояковыпуклая биологическая линза в глазу. Кривизна его поверхности может изменяться под действием глазных мышц (аккомодация), обеспечивая фокусировку изображения на сетчатке. (Билет №14)" }
        ],
        "Э": [
            { term: "Электрическая цепь", definition: "Совокупность соединённых проводниками источников электрической энергии и потребителей (нагрузок), по которым может протекать электрический ток. Обязательные элементы: источник, нагрузка, соединительные провода, ключ (для управления). (Билеты №5, №10, №15)" },
            { term: "Электрический заряд (q)", definition: "Фундаментальное свойство частиц, определяющее их электромагнитное взаимодействие. Элементарный заряд e = 1,6·10⁻¹⁹ Кл. Свойства: дискретность (кратен e), инвариантность (не зависит от скорости), сохранение в замкнутой системе. Единица: Кулон (Кл). (Билет №9)" },
            { term: "Электрический звонок", definition: "Электромеханическое устройство. При замыкании цепи электромагнит притягивает якорь с молоточком, который ударяет по чаше; одновременно размыкается контакт в цепи питания магнита, якорь возвращается пружиной, цепь вновь замыкается — цикл повторяется. Регулировочный винт изменяет расстояние между контактами для настройки чёткости срабатывания. (Билет №12)" },
            { term: "Электрический ток", definition: "Упорядоченное (направленное) движение заряженных частиц. Условия существования постоянного тока: наличие свободных носителей заряда и электрического поля в проводнике. За направление тока условно принято движение положительных зарядов (от «+» к «−» источника). В металлах ток — это дрейф электронов на фоне их теплового движения. (Билеты №5, №9, №10, №11, №12, №15)" },
            { term: "Электрическое поле", definition: "Особая форма материи, осуществляющая взаимодействие между электрическими зарядами. Свойства: создаётся зарядами и переменным магнитным полем; действует на заряды с силой Кулона; потенциально (для электростатики). (Билет №9)" },
            { term: "Электризация", definition: "Процесс приобретения макроскопическим телом электрического заряда. Способы: трением (переход электронов), соприкосновением (перераспределение заряда), через влияние (электростатическая индукция — перераспределение зарядов в проводнике под действием внешнего поля без контакта). (Билет №9)" },
            { term: "Электродвигатель постоянного тока", definition: "Машина, преобразующая электрическую энергию в механическую. Основные части: индуктор (постоянный магнит или электромагнит), якорь (вращающаяся обмотка), коллектор со щётками. Коллектор переключает направление тока в обмотке якоря каждые пол-оборота, обеспечивая неизменное направление вращающего момента. (Билет №1)" },
            { term: "Электромагнит", definition: "Катушка (соленоид) с ферромагнитным сердечником. При пропускании тока создаёт сильное магнитное поле, во много раз превышающее поле той же катушки без сердечника. Используется в электрическом звонке, реле, подъёмных кранах. (Билет №12)" },
            { term: "Электроскоп", definition: "Прибор для обнаружения электрического заряда и приблизительной оценки его величины. Состоит из металлического стержня с двумя лёгкими лепестками, помещённого в изолирующий корпус. Принцип действия: отталкивание одноимённо заряженных лепестков. (Билет №9)" }
        ]
    };

    const lettersOrder = ["А", "Б", "В", "Г", "Д", "З", "И", "К", "Л", "М", "Н", "О", "П", "Р", "С", "Т", "У", "Ф", "Х", "Э"];

    const container = document.getElementById("accordionContainer");

    lettersOrder.forEach(letter => {
        const termsArray = dictionary[letter];
        if (!termsArray || termsArray.length === 0) return;

        const letterDiv = document.createElement("div");
        letterDiv.className = "letter-item";

        const header = document.createElement("div");
        header.className = "letter-header";
        header.innerHTML = `
            <div class="letter-title">
                <div class="letter-icon">${letter}</div>
                <div class="letter-name">Буква ${letter}</div>
            </div>
            <div class="arrow-icon">▶</div>
        `;

        const termsContainer = document.createElement("div");
        termsContainer.className = "terms-list";

        const grid = document.createElement("div");
        grid.className = "terms-grid";

        termsArray.forEach(termObj => {
            const btn = document.createElement("button");
            btn.className = "term-btn";
            btn.textContent = termObj.term;
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                openModal(termObj);
            });
            grid.appendChild(btn);
        });

        termsContainer.appendChild(grid);
        letterDiv.appendChild(header);
        letterDiv.appendChild(termsContainer);
        container.appendChild(letterDiv);

        let isOpen = false;
        const arrowSpan = header.querySelector(".arrow-icon");
        header.addEventListener("click", () => {
            if (isOpen) {
                termsContainer.classList.remove("show");
                arrowSpan.classList.remove("open");
            } else {
                termsContainer.classList.add("show");
                arrowSpan.classList.add("open");
            }
            isOpen = !isOpen;
        });
    });

    const modal = document.getElementById("termModal");
    const modalTitle = document.getElementById("modalTermName");
    const modalDef = document.getElementById("modalDefinition");

    function openModal(termObj) {
        modalTitle.textContent = termObj.term;
        modalDef.textContent = termObj.definition;
        modal.style.display = "flex";
    }

    document.querySelector(".modal-close").onclick = () => {
        modal.style.display = "none";
    };
    window.onclick = (e) => {
        if (e.target === modal) modal.style.display = "none";
    };
</script>
</body>
</html>
